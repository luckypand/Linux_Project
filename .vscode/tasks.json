{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Shell: make debug",
            "type": "shell",
            "command": "make",
            "args": [
                "debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Shell"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Shell: make release",
            "type": "shell",
            "command": "make",
            "args": [
                "release"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Shell"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Shell: clean",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Shell"
            },
            "problemMatcher": []
        },
        {
            "label": "Redirect: make debug",
            "type": "shell",
            "command": "make",
            "args": [
                "debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Redirect"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Project: make debug (active file)",
            "type": "shell",
            "command": "make",
            "args": [
                "debug"
            ],
            "options": {
                "cwd": "${fileDirname}/.."
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}