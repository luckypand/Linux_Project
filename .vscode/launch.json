{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Project: Debug <active>_debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/../${fileBasenameNoExtension}_debug",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}/..",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "Project: make debug (active file)",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}